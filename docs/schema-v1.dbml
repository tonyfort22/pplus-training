// PPLUS Training schema v1
// Open this in https://dbdiagram.io or any DBML-compatible viewer

Table users {
  id uuid [pk]
  email text [not null, unique]
  role text [not null]
  auth_provider text
  created_at timestamptz [not null]
  updated_at timestamptz [not null]
}

Table coach_profiles {
  id uuid [pk]
  user_id uuid [not null, unique]
  display_name text
  organization_name text
  bio text
  created_at timestamptz [not null]
  updated_at timestamptz [not null]
}

Table athlete_profiles {
  id uuid [pk]
  user_id uuid [not null, unique]
  coach_id uuid
  first_name text
  last_name text
  date_of_birth date
  sport text
  position text
  status text
  handedness text
  units_preference text
  created_at timestamptz [not null]
  updated_at timestamptz [not null]
}

Table content_sources {
  id uuid [pk]
  code text [not null, unique]
  name text [not null]
  source_type text [not null]
  description text
  origin_url text
  import_notes text
  imported_at timestamptz
  created_at timestamptz [not null]
  updated_at timestamptz [not null]
}

Table content_collections {
  id uuid [pk]
  content_source_id uuid [not null]
  parent_collection_id uuid
  collection_type text [not null]
  name text [not null]
  slug text
  description text
  audience text
  sport text
  level text
  season_label text
  sort_order integer
  created_at timestamptz [not null]
  updated_at timestamptz [not null]
}

Table content_items {
  id uuid [pk]
  content_collection_id uuid [not null]
  parent_item_id uuid
  item_type text [not null]
  title text [not null]
  slug text
  summary text
  source_display_text text
  source_url text
  source_file_label text
  source_identifier text
  content_text text
  duration_seconds integer
  estimated_duration_minutes integer
  sort_order integer
  published_at timestamptz
  normalization_status text [not null]
  created_at timestamptz [not null]
  updated_at timestamptz [not null]
}

Table content_item_assets {
  id uuid [pk]
  content_item_id uuid [not null]
  asset_type text [not null]
  url text [not null]
  label text
  mime_type text
  provider text
  created_at timestamptz [not null]
}

Table content_item_template_maps {
  id uuid [pk]
  content_item_id uuid [not null]
  workout_template_id uuid [not null]
  mapping_type text [not null]
  created_at timestamptz [not null]
}

Table muscles {
  id uuid [pk]
  name text [not null]
  slug text [unique]
  body_region text
  thumbnail_url text
  sort_order integer
  is_active boolean [not null]
}

Table sub_muscles {
  id uuid [pk]
  muscle_id uuid [not null]
  name text [not null]
  slug text
  thumbnail_url text
  sort_order integer
  is_active boolean [not null]
}

Table exercises {
  id uuid [pk]
  name text [not null]
  slug text [unique]
  description text
  coaching_cues text
  video_url text
  thumbnail_url text
  difficulty text
  movement_pattern text
  stimulus_type text
  body_region text
  default_equipment text
  default_load_unit text
  fatigue_multiplier numeric
  axial_fatigue_multiplier numeric
  skill_fatigue_multiplier numeric
  status text
  created_by uuid
  created_at timestamptz [not null]
  updated_at timestamptz [not null]
}

Table exercise_aliases {
  id uuid [pk]
  exercise_id uuid [not null]
  alias_text text [not null]
  alias_type text [not null]
  source_system text
  created_at timestamptz [not null]
}

Table exercise_options {
  id uuid [pk]
  group_name text [not null]
  source_display_text text
  selection_rule text [not null]
  created_at timestamptz [not null]
  updated_at timestamptz [not null]
}

Table exercise_option_members {
  id uuid [pk]
  exercise_option_id uuid [not null]
  exercise_id uuid [not null]
  sort_order integer [not null]
  created_at timestamptz [not null]
}

Table exercise_muscle_maps {
  id uuid [pk]
  exercise_id uuid [not null]
  muscle_id uuid [not null]
  role text [not null]
  contribution_percent numeric
  sort_order integer
  created_at timestamptz [not null]
}

Table exercise_sub_muscle_maps {
  id uuid [pk]
  exercise_id uuid [not null]
  exercise_muscle_map_id uuid
  sub_muscle_id uuid [not null]
  role text [not null]
  contribution_percent numeric
  sort_order integer
  created_at timestamptz [not null]
}

Table workout_templates {
  id uuid [pk]
  content_item_id uuid
  coach_id uuid
  name text [not null]
  slug text
  description text
  category text
  difficulty text
  focus_area text
  training_type text
  estimated_duration_minutes integer
  thumbnail_url text
  source_type text [not null]
  template_status text [not null]
  created_at timestamptz [not null]
  updated_at timestamptz [not null]
}

Table workout_template_blocks {
  id uuid [pk]
  workout_template_id uuid [not null]
  block_code text
  block_kind text [not null]
  title text
  instructions text
  sort_order integer [not null]
  created_at timestamptz [not null]
  updated_at timestamptz [not null]
}

Table workout_template_exercises {
  id uuid [pk]
  workout_template_block_id uuid [not null]
  exercise_id uuid
  exercise_option_id uuid
  content_item_id uuid
  source_display_text text
  name_snapshot text [not null]
  notes text
  default_rest_seconds integer
  sort_order integer [not null]
  created_at timestamptz [not null]
  updated_at timestamptz [not null]
}

Table workout_template_sets {
  id uuid [pk]
  workout_template_exercise_id uuid [not null]
  sort_order integer [not null]
  set_type text [not null]
  target_reps integer
  target_load numeric
  target_load_unit text
  target_duration_seconds integer
  target_distance numeric
  target_distance_unit text
  target_rpe numeric
  target_rir numeric
  target_rest_seconds integer
  tempo_text text
  sets_reps_text text
  rest_text text
  notes text
  created_at timestamptz [not null]
  updated_at timestamptz [not null]
}

Table programs {
  id uuid [pk]
  athlete_id uuid [not null]
  coach_id uuid
  content_collection_id uuid
  name text [not null]
  description text
  start_date date [not null]
  end_date date
  status text [not null]
  created_at timestamptz [not null]
  updated_at timestamptz [not null]
}

Table program_weeks {
  id uuid [pk]
  program_id uuid [not null]
  week_index integer [not null]
  name text
  start_date date
  end_date date
  created_at timestamptz [not null]
  updated_at timestamptz [not null]
}

Table program_days {
  id uuid [pk]
  program_week_id uuid [not null]
  day_index integer [not null]
  date date
  name text
  notes text
  day_type text [not null]
  created_at timestamptz [not null]
  updated_at timestamptz [not null]
}

Table program_workouts {
  id uuid [pk]
  program_day_id uuid [not null]
  workout_template_id uuid
  content_item_id uuid
  name_snapshot text [not null]
  description_snapshot text
  category_snapshot text
  focus_area_snapshot text
  training_type_snapshot text
  estimated_duration_minutes_snapshot integer
  source_file_label_snapshot text
  sort_order integer [not null]
  status text [not null]
  created_at timestamptz [not null]
  updated_at timestamptz [not null]
}

Table program_workout_blocks {
  id uuid [pk]
  program_workout_id uuid [not null]
  workout_template_block_id uuid
  block_code_snapshot text
  block_kind_snapshot text
  title_snapshot text
  instructions_snapshot text
  sort_order integer [not null]
  created_at timestamptz [not null]
  updated_at timestamptz [not null]
}

Table program_workout_exercises {
  id uuid [pk]
  program_workout_block_id uuid [not null]
  workout_template_exercise_id uuid
  exercise_id uuid
  exercise_option_id uuid
  selected_exercise_id uuid
  content_item_id uuid
  source_display_text_snapshot text
  name_snapshot text [not null]
  notes_snapshot text
  default_rest_seconds integer
  sort_order integer [not null]
  created_at timestamptz [not null]
  updated_at timestamptz [not null]
}

Table program_workout_sets {
  id uuid [pk]
  program_workout_exercise_id uuid [not null]
  workout_template_set_id uuid
  sort_order integer [not null]
  set_type text [not null]
  target_reps integer
  target_load numeric
  target_load_unit text
  target_duration_seconds integer
  target_distance numeric
  target_distance_unit text
  target_rpe numeric
  target_rir numeric
  target_rest_seconds integer
  tempo_text text
  sets_reps_text text
  rest_text text
  notes text
  created_at timestamptz [not null]
  updated_at timestamptz [not null]
}

Table workout_sessions {
  id uuid [pk]
  athlete_id uuid [not null]
  coach_id uuid
  program_id uuid
  program_day_id uuid
  program_workout_id uuid
  workout_template_id uuid
  name_snapshot text [not null]
  status text [not null]
  started_at timestamptz
  completed_at timestamptz
  elapsed_seconds integer [not null]
  notes text
  perceived_difficulty numeric
  total_exercises_count integer [not null]
  completed_exercises_count integer [not null]
  total_sets_count integer [not null]
  completed_sets_count integer [not null]
  created_at timestamptz [not null]
  updated_at timestamptz [not null]
}

Table workout_session_blocks {
  id uuid [pk]
  workout_session_id uuid [not null]
  program_workout_block_id uuid
  block_code_snapshot text
  block_kind_snapshot text
  title_snapshot text
  sort_order integer [not null]
  created_at timestamptz [not null]
  updated_at timestamptz [not null]
}

Table workout_session_exercises {
  id uuid [pk]
  workout_session_id uuid [not null]
  workout_session_block_id uuid
  program_workout_exercise_id uuid
  exercise_id uuid
  selected_exercise_id uuid
  source_display_text_snapshot text
  name_snapshot text [not null]
  sort_order integer [not null]
  status text [not null]
  notes text
  default_rest_seconds integer
  created_at timestamptz [not null]
  updated_at timestamptz [not null]
}

Table workout_session_sets {
  id uuid [pk]
  workout_session_exercise_id uuid [not null]
  program_workout_set_id uuid
  sort_order integer [not null]
  set_type text [not null]
  prescribed_reps integer
  prescribed_load numeric
  prescribed_load_unit text
  prescribed_duration_seconds integer
  prescribed_distance numeric
  prescribed_distance_unit text
  prescribed_rpe numeric
  prescribed_rir numeric
  prescribed_rest_seconds integer
  actual_reps integer
  actual_load numeric
  actual_load_unit text
  actual_duration_seconds integer
  actual_distance numeric
  actual_distance_unit text
  actual_rpe numeric
  actual_rir numeric
  actual_rest_seconds integer
  completed_at timestamptz
  is_completed boolean [not null]
  notes text
  created_at timestamptz [not null]
  updated_at timestamptz [not null]
}

Table rest_timer_states {
  id uuid [pk]
  workout_session_id uuid [not null]
  workout_session_set_id uuid
  mode text [not null]
  duration_seconds integer [not null]
  remaining_seconds integer [not null]
  started_at timestamptz [not null]
  ended_at timestamptz
  is_running boolean [not null]
  created_at timestamptz [not null]
  updated_at timestamptz [not null]
}

Table muscle_load_events {
  id uuid [pk]
  athlete_id uuid [not null]
  workout_session_id uuid [not null]
  workout_session_exercise_id uuid
  workout_session_set_id uuid
  exercise_id uuid
  muscle_id uuid
  sub_muscle_id uuid
  is_sub_muscle boolean [not null]
  event_date date [not null]
  percent numeric
  score numeric
  created_at timestamptz [not null]
}

Table session_muscle_load_summaries {
  id uuid [pk]
  athlete_id uuid [not null]
  workout_session_id uuid [not null]
  muscle_id uuid [not null]
  event_date date [not null]
  percent numeric
  score numeric
  cap numeric
  level text
  created_at timestamptz [not null]
}

Table exercise_performance_snapshots {
  id uuid [pk]
  athlete_id uuid [not null]
  exercise_id uuid [not null]
  workout_session_id uuid
  workout_session_exercise_id uuid
  metric_type text [not null]
  load numeric
  reps integer
  sets integer
  duration_seconds integer
  distance numeric
  unit text
  body_region text
  log_date date [not null]
  estimated_one_rep_max numeric
  notes text
  created_at timestamptz [not null]
}

Table recovery_snapshots {
  id uuid [pk]
  athlete_id uuid [not null]
  snapshot_date date [not null]
  muscle_id uuid
  sub_muscle_id uuid
  fatigue_score numeric
  recovery_score numeric
  recovery_percent numeric
  readiness_level text
  source_window_days integer
  created_at timestamptz [not null]
}

Table body_metric_logs {
  id uuid [pk]
  athlete_id uuid [not null]
  coach_id uuid
  metric_type text [not null]
  value numeric [not null]
  unit text
  recorded_at timestamptz [not null]
  source text
  notes text
  progress_photo_url text
  created_at timestamptz [not null]
}

Ref: coach_profiles.user_id > users.id
Ref: athlete_profiles.user_id > users.id
Ref: athlete_profiles.coach_id > coach_profiles.id

Ref: content_collections.content_source_id > content_sources.id
Ref: content_collections.parent_collection_id > content_collections.id
Ref: content_items.content_collection_id > content_collections.id
Ref: content_items.parent_item_id > content_items.id
Ref: content_item_assets.content_item_id > content_items.id

Ref: sub_muscles.muscle_id > muscles.id
Ref: exercises.created_by > users.id
Ref: exercise_aliases.exercise_id > exercises.id
Ref: exercise_option_members.exercise_option_id > exercise_options.id
Ref: exercise_option_members.exercise_id > exercises.id
Ref: exercise_muscle_maps.exercise_id > exercises.id
Ref: exercise_muscle_maps.muscle_id > muscles.id
Ref: exercise_sub_muscle_maps.exercise_id > exercises.id
Ref: exercise_sub_muscle_maps.exercise_muscle_map_id > exercise_muscle_maps.id
Ref: exercise_sub_muscle_maps.sub_muscle_id > sub_muscles.id

Ref: workout_templates.content_item_id > content_items.id
Ref: workout_templates.coach_id > coach_profiles.id
Ref: workout_template_blocks.workout_template_id > workout_templates.id
Ref: workout_template_exercises.workout_template_block_id > workout_template_blocks.id
Ref: workout_template_exercises.exercise_id > exercises.id
Ref: workout_template_exercises.exercise_option_id > exercise_options.id
Ref: workout_template_exercises.content_item_id > content_items.id
Ref: workout_template_sets.workout_template_exercise_id > workout_template_exercises.id
Ref: content_item_template_maps.content_item_id > content_items.id
Ref: content_item_template_maps.workout_template_id > workout_templates.id

Ref: programs.athlete_id > athlete_profiles.id
Ref: programs.coach_id > coach_profiles.id
Ref: programs.content_collection_id > content_collections.id
Ref: program_weeks.program_id > programs.id
Ref: program_days.program_week_id > program_weeks.id
Ref: program_workouts.program_day_id > program_days.id
Ref: program_workouts.workout_template_id > workout_templates.id
Ref: program_workouts.content_item_id > content_items.id
Ref: program_workout_blocks.program_workout_id > program_workouts.id
Ref: program_workout_blocks.workout_template_block_id > workout_template_blocks.id
Ref: program_workout_exercises.program_workout_block_id > program_workout_blocks.id
Ref: program_workout_exercises.workout_template_exercise_id > workout_template_exercises.id
Ref: program_workout_exercises.exercise_id > exercises.id
Ref: program_workout_exercises.exercise_option_id > exercise_options.id
Ref: program_workout_exercises.selected_exercise_id > exercises.id
Ref: program_workout_exercises.content_item_id > content_items.id
Ref: program_workout_sets.program_workout_exercise_id > program_workout_exercises.id
Ref: program_workout_sets.workout_template_set_id > workout_template_sets.id

Ref: workout_sessions.athlete_id > athlete_profiles.id
Ref: workout_sessions.coach_id > coach_profiles.id
Ref: workout_sessions.program_id > programs.id
Ref: workout_sessions.program_day_id > program_days.id
Ref: workout_sessions.program_workout_id > program_workouts.id
Ref: workout_sessions.workout_template_id > workout_templates.id
Ref: workout_session_blocks.workout_session_id > workout_sessions.id
Ref: workout_session_blocks.program_workout_block_id > program_workout_blocks.id
Ref: workout_session_exercises.workout_session_id > workout_sessions.id
Ref: workout_session_exercises.workout_session_block_id > workout_session_blocks.id
Ref: workout_session_exercises.program_workout_exercise_id > program_workout_exercises.id
Ref: workout_session_exercises.exercise_id > exercises.id
Ref: workout_session_exercises.selected_exercise_id > exercises.id
Ref: workout_session_sets.workout_session_exercise_id > workout_session_exercises.id
Ref: workout_session_sets.program_workout_set_id > program_workout_sets.id
Ref: rest_timer_states.workout_session_id > workout_sessions.id
Ref: rest_timer_states.workout_session_set_id > workout_session_sets.id

Ref: muscle_load_events.athlete_id > athlete_profiles.id
Ref: muscle_load_events.workout_session_id > workout_sessions.id
Ref: muscle_load_events.workout_session_exercise_id > workout_session_exercises.id
Ref: muscle_load_events.workout_session_set_id > workout_session_sets.id
Ref: muscle_load_events.exercise_id > exercises.id
Ref: muscle_load_events.muscle_id > muscles.id
Ref: muscle_load_events.sub_muscle_id > sub_muscles.id
Ref: session_muscle_load_summaries.athlete_id > athlete_profiles.id
Ref: session_muscle_load_summaries.workout_session_id > workout_sessions.id
Ref: session_muscle_load_summaries.muscle_id > muscles.id
Ref: exercise_performance_snapshots.athlete_id > athlete_profiles.id
Ref: exercise_performance_snapshots.exercise_id > exercises.id
Ref: exercise_performance_snapshots.workout_session_id > workout_sessions.id
Ref: exercise_performance_snapshots.workout_session_exercise_id > workout_session_exercises.id
Ref: recovery_snapshots.athlete_id > athlete_profiles.id
Ref: recovery_snapshots.muscle_id > muscles.id
Ref: recovery_snapshots.sub_muscle_id > sub_muscles.id
Ref: body_metric_logs.athlete_id > athlete_profiles.id
Ref: body_metric_logs.coach_id > coach_profiles.id
