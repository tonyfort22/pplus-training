{
  "name": "pplus-training",
  "private": true,
  "type": "module",
  "version": "0.1.0",
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "dev:mobile": "pnpm --dir apps/mobile dev",
    "dev:mobile:warm": "pnpm --dir apps/mobile dev:warm",
    "dev:mobile:home": "pnpm --dir apps/mobile dev:home",
    "dev:mobile:home:warm": "pnpm --dir apps/mobile dev:home:warm",
    "dev:mobile:phone": "pnpm --dir apps/mobile dev:phone",
    "dev:mobile:phone:warm": "pnpm --dir apps/mobile dev:phone:warm",
    "dev:web": "pnpm --dir apps/web dev",
    "supabase:db:push": "supabase db push --workdir infra",
    "supabase:functions:serve:invite": "supabase functions serve send-athlete-invitation --workdir infra/supabase --env-file infra/supabase/.env.example",
    "supabase:functions:deploy:invite": "supabase functions deploy send-athlete-invitation --workdir infra/supabase",
    "lint": "pnpm -r lint",
    "test": "node --test",
    "test:mobile": "node apps/mobile/testing/run-mobile-tests.js",
    "test:web": "node apps/web/testing/run-web-tests.js",
    "test:web:coverage": "node apps/web/testing/coverage-summary.js",
    "verify:local": "pnpm test",
    "verify:ci": "pnpm test",
    "test:web:browser": "node apps/web/testing/run-browser-tests.js --list",
    "test:web:browser:fixtures:setup": "node apps/web/testing/browser-workflow-fixtures.js setup",
    "test:web:browser:fixtures:teardown": "node apps/web/testing/browser-workflow-fixtures.js teardown"
  }
}
